rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ========================================
    // Photos de profil utilisateur
    // Le user ne peut écrire que dans son propre dossier.
    // ========================================
    match /users/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      // BUG #107 — élargi à audio/* pour permettre l'accroche vocale
      // (users/{uid}/voice-prompt.webm). Anti-spoof : auth.uid == userId.
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*|audio/.*');
    }

    // ========================================
    // Photos / vidéos d'activités (partenaires)
    // TODO Phase 8 : vérifier que l'user est partner de l'activity.
    // ========================================
    match /activities/{activityId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*|video/.*');
    }

    // BUG #30 étape 3 — Vidéos migrées Drive→Storage par Cloud Function
    // (migrateDriveVideosTrigger). Path : activities/{actId}/videos/{fileId}.mp4.
    // Write Admin-only (CF via Admin SDK qui bypass les rules de toute façon —
    // ce `if false` est defense-in-depth pour bloquer write client direct sur ce
    // sub-path). Read auth-only (cohérent autres medias activities).
    // Size jusqu'à 200MB (limit côté CF, rules juste defense-in-depth).
    match /activities/{activityId}/videos/{fileName} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ========================================
    // BUG #106 — Media activités partner uploads (MediaManager).
    // Path: partners/{partnerId}/activities/{timestamp}-{filename}
    // Anti-spoof : write requires request.auth.uid == partnerId.
    // Phase 9.5 c4 originally images only (5MB) ; étendu aux vidéos depuis #51
    // car les coachs uploadent maintenant des clips démo. Limite 50MB pour
    // permettre des clips ~30s en HD raisonnable. La taille MAX côté client
    // est plus restrictive (cf. uploadActivityMedia.ts STORAGE_UPLOAD_MAX_BYTES_VIDEO).
    // ========================================
    match /partners/{partnerId}/activities/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == partnerId
        && request.resource.size < 50 * 1024 * 1024
        && request.resource.contentType.matches('image/.*|video/.*');
    }

    // ========================================
    // Pièces jointes chat
    // TODO Phase 8 : vérifier que l'user est participant du chat.
    // ========================================
    match /chats/{chatId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 25 * 1024 * 1024;
    }

    // ========================================
    // Avatars / assets génériques uploadés via le formulaire profil
    // (au cas où le code utilise un autre path que users/{uid})
    // ========================================
    match /avatars/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    match /profile-photos/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // ========================================
    // BUG #103 — Selfies de vérification d'identité.
    // L'utilisateur écrit son propre selfie dans selfies/{uid}/{timestamp}.jpg.
    // Lu par les admins via console pour valider (voir AdminSelfieReviewSection).
    // Anti-spoof : auth.uid == userId pour l'écriture.
    // ========================================
    match /selfies/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // ========================================
    // Fix #128 — Logos de marque (PWA, favicon, splash, apple-touch...)
    // Path : brand/v{timestamp}/{slot}.png — uploadé par /admin/manage > Logos du site.
    // Read : PUBLIC (favicon + manifest + splash sont chargés par navigateurs non-auth).
    // Write : authenticated user uniquement. Defense-in-depth via UI : seul l'admin
    //   peut voir/utiliser BrandLogoManager (guard role=='admin' dans /admin/layout.tsx).
    //   TODO : durcir avec firestore.get(users/$uid).role == 'admin' une fois propagation
    //   IAM cross-service confirmée et users/{uid}.role bien renseigné en prod.
    // ========================================
    match /brand/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // ========================================
    // Default deny (sécurité)
    // ========================================
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
