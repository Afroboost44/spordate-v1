rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // === HELPERS ===
    function isAuth() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return request.auth.uid == uid;
    }
    function isAdmin() {
      return isAuth()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // Phase 6 anti-cheat V7 — interdit le downgrade de Session.maxParticipants sous currentParticipants.
    // Autorise : upgrade (5→10), no-change, ou égalité (5→5 = ferme aux nouvelles bookings).
    // Bloque  : downgrade strict (8→3 si currentParticipants=5).
    // Admin skip cette garde via la branche isAdmin() du allow update sessions — emergency edits permises.
    // Note : helper spécifique sessions/{id} (accède maxParticipants + currentParticipants) ; n'invoquer
    //        que depuis ce match block, sinon résultats imprévisibles sur autres collections.
    function validMaxParticipantsUpdate() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(['maxParticipants'])
        || request.resource.data.maxParticipants >= resource.data.currentParticipants;
    }

    // Phase 6 anti-cheat V9 — interdit toute modification de Session.pricingTiers après le 1er booking.
    // Autorise : modification libre tant que currentParticipants == 0 (avant tout booking, workflow normal pré-launch).
    // Bloque  : toute modif (price, deletion d'un tier, ajout d'un tier) si currentParticipants > 0.
    // Admin skip cette garde via la branche isAdmin() du allow update sessions — emergency edits permises.
    // Note : helper spécifique sessions/{id} (accède pricingTiers + currentParticipants) ; n'invoquer
    //        que depuis ce match block, sinon résultats imprévisibles sur autres collections.
    function validPricingTiersUpdate() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(['pricingTiers'])
        || resource.data.currentParticipants == 0;
    }

    // Fix B B3 — defense-in-depth pour Fix B Option 3 (create/edit/delete
    // sessions par partner via /api/partner/sessions/*). Le endpoint applique
    // déjà les checks ownership + V9 freeze, mais ces rules empêchent un
    // partner malveillant de bypasser via DevTools direct Firestore write.
    //
    // Whitelist : seuls ces champs peuvent être modifiés par le partner-owner.
    // - pricingTiers / pricingMode : B2 override prix
    // - startAt / endAt / chatOpenAt / chatCloseAt : Option 3 modif date+heure
    // - maxParticipants : update capacity (déjà gated par validMaxParticipantsUpdate)
    // - status / updatedAt : lifecycle + audit
    //
    // Blacklist implicite (PAS dans la whitelist, rejet rules) :
    // - currentParticipants / currentTier / currentPrice : server-only (webhook)
    // - partnerId / activityId / creatorId / createdBy / createdAt : immutables
    //
    // V9 freeze : aucune modif si currentParticipants > 0 (sauf admin via
    // branche supérieure du allow update). Cohérent avec validPricingTiersUpdate
    // mais étendu à TOUS les fields (au lieu de juste pricingTiers).
    function validPartnerSessionUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'pricingTiers',
          'pricingMode',
          'startAt',
          'endAt',
          'chatOpenAt',
          'chatCloseAt',
          'maxParticipants',
          'status',
          'updatedAt'
        ])
        && resource.data.currentParticipants == 0
        && validMaxParticipantsUpdate();
    }

    // === USERS ===
    // Phase 9 SC6 c3/4 — soft delete user-facing UI (RGPD/nLPD Art. 17).
    // Owner allowed full update inclut softDelete fields (preserved Phase 9).
    // Phase 10 polish : tighten owner update à champs whitelist via diff.affectedKeys().hasOnly.
    match /users/{userId} {
      allow read: if isAuth();
      allow create: if isOwner(userId);
      // Update : owner full update OU admin OU owner soft-delete only path (defense-in-depth).
      // Le 3e path est redondant (owner allowed full) mais documenté pour audit
      // — préserve possibilité Phase 10 de tighten owner update à champs whitelist.
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();

      match /preferences/{doc} {
        allow read, write: if isOwner(userId);
      }
    }

    // === MATCHES ===
    match /matches/{matchId} {
      allow read: if isAuth() && request.auth.uid in resource.data.userIds;
      allow create: if isAuth();
      allow update: if isAuth() && request.auth.uid in resource.data.userIds;
      allow delete: if isAdmin();
    }

    // === LIKES (Phase 9.5 c38a / c38a-fix — flow Tinder-like, doc id = ${fromUid}_${toUid}) ===
    // - create : auth uid == fromUid (un user ne peut liker qu'en son nom)
    // - read : auth uid in [fromUid, toUid] (visibilité bilatérale) ou admin
    // - update/delete : admin only (likes immutables côté user)
    // c38a-fix : ajout `is string` defensive pour rejeter explicitement les
    // champs falsy/undefined (au lieu de comparer silencieusement à null).
    match /likes/{likeId} {
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.fromUid
        && request.resource.data.fromUid is string
        && request.resource.data.toUid is string
        && request.resource.data.fromUid != request.resource.data.toUid;
      // c38a-fix3 : rollback update permission. handleLike utilise désormais
      // getDoc check + setDoc create only (skip-if-exists), donc les writes
      // sont uniquement CREATE — pas d'UPDATE. Likes immutables côté user :
      // pas de retrait Tinder-style, pas de toggle seen via client. Future
      // Premium feature (mark as seen) passera par /api/admin si besoin.
      // BUG #27 — `resource == null` allow check d'existence sur doc non-existant
      // (snap.exists()=false sans throw permission-denied). handleLike fait
      // getDoc(likes/{user.uid}_{targetUid}) avant setDoc pour skip-if-exists
      // (Phase 9.5 c38a-fix3) → si le doc n'existe pas, l'évaluation
      // `auth.uid == resource.data.fromUid` avec resource=null → tous les OR
      // branches false → permission-denied THROW. Sans cette branche, le flow
      // handleLike casse au premier like sur un nouveau profil.
      allow read: if request.auth != null && (
        resource == null
        || request.auth.uid == resource.data.fromUid
        || request.auth.uid == resource.data.toUid
        || isAdmin()
      );
      allow update, delete: if isAdmin();
    }

    // === PASSES (BUG #25 — Tinder-like dismiss, doc id = ${fromUid}_${toUid}) ===
    // Persist le X click (pass) pour exclure le profil de la stack /discovery
    // au prochain mount. Privé au fromUid (le toUid ne sait pas qu'il a été
    // passé). Pattern aligné likes/ pour create rules, mais read fromUid-only.
    match /passes/{passId} {
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.fromUid
        && request.resource.data.fromUid is string
        && request.resource.data.toUid is string
        && request.resource.data.fromUid != request.resource.data.toUid;
      // Read réservé au fromUid (privé) + admin. Pas de visibilité bilatérale
      // comme likes (pour préserver la confidentialité du "pass").
      // BUG #27 — `resource == null` allow check d'existence sur doc non-existant
      // (cohérent likes/ — handlePass utilise même pattern getDoc + setDoc
      // skip-if-exists). Sans cette branche, handlePass throw silencieux dans
      // le catch warn → passes pas persistés → profils ré-apparaissent.
      allow read: if request.auth != null && (
        resource == null
        || request.auth.uid == resource.data.fromUid
        || isAdmin()
      );
      allow update, delete: if isAdmin();
    }

    // === ACTIVITIES (public read, partner CRUD) ===
    // Phase 9 SC6 c1/4 — audienceType enum validation (Q1=A whitelist)
    function validAudienceType(data) {
      return !('audienceType' in data)
        || data.audienceType in ['all', 'women-only', 'men-only', 'mixed-priority-women'];
    }
    match /activities/{activityId} {
      allow read: if true;
      allow create: if isAuth() && validAudienceType(request.resource.data);
      allow update: if isAuth()
        && (resource.data.partnerId == request.auth.uid || isAdmin())
        && validAudienceType(request.resource.data);
      allow delete: if isAuth() && (resource.data.partnerId == request.auth.uid || isAdmin());
    }

    // === BOOKINGS ===
    match /bookings/{bookingId} {
      allow read: if isAuth() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuth();
      // Update : admin OR owner setting only `excusedAt` (Phase 9 SC5 c1/4 — denorm fast-check
      // pour UI ; source-of-truth = /excuses/{id} doc via createExcuse anti-spoof rule).
      allow update: if isAdmin()
        || (
          isAuth()
          && resource.data.userId == request.auth.uid
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['excusedAt'])
          && request.resource.data.excusedAt == request.time
        );
      allow delete: if false;
    }

    // === CREDITS (server-side only) ===
    match /credits/{creditId} {
      allow read: if isAuth() && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    // === TRANSACTIONS (server-side only) ===
    match /transactions/{transactionId} {
      allow read: if isAuth() && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if false;
    }

    // === CREATORS ===
    match /creators/{creatorId} {
      allow read: if isAuth();
      allow create: if isOwner(creatorId);
      allow update: if isOwner(creatorId) || isAdmin();
      allow delete: if isAdmin();
    }

    // === PARTNERS (public read) ===
    match /partners/{partnerId} {
      allow read: if true;
      allow create: if isAuth();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // === REFERRALS (server-side only) ===
    match /referrals/{referralId} {
      allow read: if isAuth()
        && (resource.data.referrerId == request.auth.uid
            || resource.data.referredUserId == request.auth.uid
            || isAdmin());
      allow write: if false;
    }

    // === INVITES (Phase 8 sub-chantier 4 — Invite Individuel doctrine §E) ===
    // Doc-id pattern strict : `${fromUserId}_${toUserId}_${sessionId}` (anti-doublon Q10=B).
    // Create : auth uid == fromUserId + status='pending' initial + immutable fields + doc-id pattern.
    // Read : participants seulement (fromUserId OR toUserId) — privacy.
    // Update : transitions strictes status pending → accepted (toUserId) | declined (toUserId)
    //          | expired (Admin SDK only, via /api/invites cron Phase 9). Champs core immuables.
    // Delete : interdit (audit trail Phase 9 KPIs).
    match /invites/{inviteId} {
      allow read: if isAuth()
        && (resource.data.fromUserId == request.auth.uid
            || resource.data.toUserId == request.auth.uid
            || isAdmin());

      // Create : strict defense-in-depth (Phase 8 SC4 commit 1/6)
      allow create: if isAuth()
        // Anti-spoof : fromUserId == auth.uid
        && request.resource.data.fromUserId == request.auth.uid
        // Anti self-invite : fromUserId ≠ toUserId
        && request.resource.data.fromUserId != request.resource.data.toUserId
        // Status initial = 'pending' uniquement
        && request.resource.data.status == 'pending'
        // toUserId + activityId + sessionId présents et type string
        && request.resource.data.toUserId is string
        && request.resource.data.toUserId.size() > 0
        && request.resource.data.activityId is string
        && request.resource.data.activityId.size() > 0
        // sessionId obligatoire pour anti-doublon doc-id (Q10=B)
        && request.resource.data.sessionId is string
        && request.resource.data.sessionId.size() > 0
        // Doc-id pattern strict : `${fromUserId}_${toUserId}_${sessionId}`
        && inviteId == request.resource.data.fromUserId + '_' + request.resource.data.toUserId + '_' + request.resource.data.sessionId
        // expiresAt présent + > now (anti-backdate / anti-already-expired)
        && request.resource.data.expiresAt is timestamp
        && request.resource.data.expiresAt > request.time
        // createdAt = server time (anti-backdate)
        && request.resource.data.createdAt == request.time
        // Phase 9 SC2 c1/6 — mode validation (optional, default 'individual')
        // Si présent : doit être enum 'individual'|'split'|'gift'
        && (!('mode' in request.resource.data) ||
            request.resource.data.mode in ['individual', 'split', 'gift'])
        // Phase 9 SC2 c1/6 — montants split/gift (optional, int >= 0 si présents)
        && (!('splitInviterAmountCents' in request.resource.data) ||
            (request.resource.data.splitInviterAmountCents is int
              && request.resource.data.splitInviterAmountCents >= 0))
        && (!('splitInviteeAmountCents' in request.resource.data) ||
            (request.resource.data.splitInviteeAmountCents is int
              && request.resource.data.splitInviteeAmountCents >= 0))
        // Keys whitelist (Phase 8 SC4 commit 1/6 + Phase 9 SC2 c1/6 modes)
        && request.resource.data.keys().hasOnly([
             'inviteId',
             'fromUserId',
             'toUserId',
             'activityId',
             'sessionId',
             'status',
             'expiresAt',
             'message',
             'createdAt',
             // Phase 9 SC2 c1/6 — modes Split/Gift
             'mode',
             'splitInviterAmountCents',
             'splitInviteeAmountCents'
           ]);

      // Update : transitions strictes (toUserId only pour accept/decline)
      // Champs core (fromUserId, toUserId, activityId, sessionId, createdAt) immuables.
      allow update: if isAuth()
        && resource.data.status == 'pending'
        && resource.data.fromUserId == request.resource.data.fromUserId
        && resource.data.toUserId == request.resource.data.toUserId
        && resource.data.activityId == request.resource.data.activityId
        && resource.data.sessionId == request.resource.data.sessionId
        && resource.data.createdAt == request.resource.data.createdAt
        && (
          // Path (a) : toUserId accepts → status='accepted' + acceptedAt
          (request.auth.uid == resource.data.toUserId
            && request.resource.data.status == 'accepted'
            && request.resource.data.acceptedAt == request.time)
          ||
          // Path (b) : toUserId declines → status='declined' + declinedAt
          (request.auth.uid == resource.data.toUserId
            && request.resource.data.status == 'declined'
            && request.resource.data.declinedAt == request.time)
        );

      allow delete: if false;
    }

    // === PAYOUTS ===
    match /payouts/{payoutId} {
      allow read: if isAuth()
        && (resource.data.creatorId == request.auth.uid || isAdmin());
      allow create: if isAuth()
        && request.resource.data.creatorId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if false;
    }

    // === ANALYTICS (admin only) ===
    match /analytics/{doc=**} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // === CHATS ===
    // Phase 9.5 c41 — Single source of truth = matches/{chatId}.userIds.
    // Avant : read/create rules checkaient chats.participants, qui pouvait
    // driver (dedupe-matches.ts c39 ne migre pas chats/, unlockChat + stripe
    // webhook créent messages sans créer le parent chats/{matchId}). Si
    // chats.participants était stale ou incomplet → permission-denied silencieux
    // côté listener → "AUCUN message visible" pour l'autre participant.
    // Après : rules check matches.userIds (toujours bon, écrit atomiquement à
    // la création du match). chats.participants reste pour usage server-side
    // (suggest-activities API) mais n'est plus gate d'accès.
    match /chats/{chatId} {
      allow read: if isAuth()
        && request.auth.uid in get(/databases/$(database)/documents/matches/$(chatId)).data.userIds;
      allow create: if isAuth()
        && request.auth.uid in get(/databases/$(database)/documents/matches/$(chatId)).data.userIds;
      // Phase 8 SC2 commit 1/6 — anti-leak self-only update sur leakBySender :
      // si leakBySender est touché, la diff ne peut contenir QUE auth.uid.
      // Empêche un participant d'incrémenter le compteur de l'autre (anti-spoof).
      // Si leakBySender pas dans diff → comportement Phase 1 inchangé (lastMessage etc.).
      allow update: if isAuth()
        && request.auth.uid in get(/databases/$(database)/documents/matches/$(chatId)).data.userIds
        && (
          !('leakBySender' in request.resource.data.diff(resource.data).affectedKeys())
          || request.resource.data.leakBySender.diff(resource.data.get('leakBySender', {})).affectedKeys().hasOnly([request.auth.uid])
        );
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isAuth()
          && request.auth.uid in get(/databases/$(database)/documents/matches/$(chatId)).data.userIds;
        allow create: if isAuth()
          && request.auth.uid in get(/databases/$(database)/documents/matches/$(chatId)).data.userIds
          // Phase 8 SC3 commit 1/6 (anti-spoof) : senderId doit être l'auteur authentifié.
          // Empêche un client de créer un faux bot message senderId='system' (Q9=A — seul Admin SDK
          // serveur peut écrire senderId='system' via /api/suggest-activities, bypass des rules).
          && request.resource.data.senderId == request.auth.uid
          && get(/databases/$(database)/documents/matches/$(chatId)).data.chatUnlocked == true
          // Phase 8 sub-chantier 1 (inversion §A doctrine "chat reste ouvert post-event") :
          // - autoriser create si session.status='completed' (était bloqué Phase 1)
          // - garder le block si session.status='cancelled' (chat fermé sur annulation)
          // - rétro-compat legacy match sans sessionId (comportement inchangé Phase 1)
          && (
            !('sessionId' in get(/databases/$(database)/documents/matches/$(chatId)).data)
            || get(/databases/$(database)/documents/matches/$(chatId)).data.sessionId == ''
            || get(/databases/$(database)/documents/sessions/$(get(/databases/$(database)/documents/matches/$(chatId)).data.sessionId)).data.status != 'cancelled'
          )
          // Phase 8 sub-chantier 1 (additif §A modèle crédits) :
          // - check credits sender ≥ 1 (defense-in-depth ; consume effectif côté service).
          //   Texte=1 crédit (doctrine §A). Photo/vidéo defer Phase 9.
          //   Q7=A reco : cross-doc get accepté pour defense-in-depth, +1 read/message.
          // BUG #36 — activity_invite gratuit (pas de check credits). Le payload
          // include obligatoirement invite.activityId + inviteMode + inviteStatus.
          && (
            request.resource.data.type == 'activity_invite'
            || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.credits >= 1
          );
        // BUG #36 — update autorisé pour activity_invite uniquement, par receiver
        // (auth.uid !== senderId, in userIds), seulement inviteStatus/timestamps,
        // depuis pending uniquement (transitions finales immutables).
        allow update: if isAuth()
          && request.auth.uid in get(/databases/$(database)/documents/matches/$(chatId)).data.userIds
          && resource.data.type == 'activity_invite'
          && resource.data.senderId != request.auth.uid
          && resource.data.inviteStatus == 'pending'
          && request.resource.data.inviteStatus in ['accepted', 'declined']
          // Diff : seuls inviteStatus + timestamps de finalisation peuvent muter
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['inviteStatus', 'inviteAcceptedAt', 'inviteDeclinedAt']);
        allow delete: if false;
      }
    }

    // === AI SCAN LOGS (Phase 8 sub-chantier 1) ===
    // Doctrine §C.Q2 : logs anti-leak L1 + L2 IA = score + motif + hash anonyme.
    // Pas de contenu lisible. Purge cron Phase 9 +30j.
    //
    // Phase 8 SC1 commit 3/5 : create autorisé client-side via sendMessage()
    // avec defense-in-depth strict (anti-spoof senderId, ranges, enum motive,
    // hash format SHA-256, anti-backdate, keys whitelist). Cf. service
    // src/services/firestore.ts sendMessage().
    match /aiScanLogs/{scanLogId} {
      allow read: if isAdmin();
      allow create: if isAuth()
        // Anti-spoof : senderId doit être l'auteur authentifié
        && request.resource.data.senderId == request.auth.uid
        // chatId présence + type string
        && request.resource.data.chatId is string
        && request.resource.data.chatId.size() > 0
        // Score ∈ [0,1]
        && request.resource.data.score is number
        && request.resource.data.score >= 0
        && request.resource.data.score <= 1
        // Motive enum SC1 (regex L1) + SC2 (IA L2 hybride) — doctrine §C.Q2 traçabilité tuning
        && request.resource.data.motive in [
          'phone-ch', 'phone-intl', 'email', 'handle', 'domain', 'keyword', 'clean',
          'ai-leak-likely', 'ai-leak-unlikely', 'ai-error'
        ]
        // messageHash format SHA-256 hex (64 chars)
        && request.resource.data.messageHash is string
        && request.resource.data.messageHash.size() == 64
        && request.resource.data.messageHash.matches('^[a-f0-9]{64}$')
        // createdAt = request.time (anti-backdate)
        && request.resource.data.createdAt == request.time
        // Keys whitelist (anti-injection champs additionnels)
        && request.resource.data.keys().hasOnly(['scanLogId', 'chatId', 'senderId', 'score', 'motive', 'messageHash', 'createdAt']);
      allow update, delete: if false;
    }

    // === NOTIFICATIONS (anyone can create for partner requests, owner reads, admin manages) ===
    match /notifications/{notificationId} {
      allow read: if isAuth() && (resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isAuth() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if true;
      // Phase 9.5 c53 — owner peut hard-delete sa propre notification
      // (cohérent UX "X = suppression" remplace dismissedAt c44/c52).
      // L'endpoint /api/notifications/[id] DELETE utilise Admin SDK qui
      // bypass déjà les rules — cette autorisation client est defense-in-depth.
      allow delete: if isAuth() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // === BOOSTS (public read for discovery, authenticated create) ===
    match /boosts/{boostId} {
      allow read: if true;
      allow create: if isAuth();
      allow update: if isAuth() && (resource.data.partnerId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    // === PARTNER REQUESTS (public create, admin read/update) ===
    match /partnerRequests/{requestId} {
      allow create: if true;
      allow read, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // === ERROR LOGS ===
    match /errorLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuth();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // === SETTINGS (admin only — pricing, config, etc.) ===
    match /settings/{doc} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // === PRICING (admin only) ===
    match /pricing/{doc} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // === PROMOS (admin only) ===
    match /promos/{doc} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // === SESSIONS ===
    // Occurrences datées d'une Activity (Phase 1 du système "Dates par Activités").
    // Les champs currentParticipants/currentTier/currentPrice ne sont écrits QUE par le serveur
    // (webhook Stripe + crons Phase 7) via l'Admin SDK qui bypass les rules.
    //
    // Phase 5 : read PUBLIC (cohérent avec activities/ ligne 39 — pas de PII dans les
    // documents session, contenu marketing/discovery indispensable au SSR de /sessions
    // sans login. Le ReserveButton déclenche le redirect login uniquement au clic.).
    match /sessions/{sessionId} {
      allow read: if true;
      allow create: if isAuth()
        && (
          isAdmin()
          || get(/databases/$(database)/documents/activities/$(request.resource.data.activityId)).data.partnerId == request.auth.uid
        );
      // Fix B B3 — partner update via validPartnerSessionUpdate (whitelist +
      // V9 freeze global). Couvre create/edit prix B2 + date+heure Option 3.
      allow update: if isAuth()
        && (
          isAdmin()
          || (
            get(/databases/$(database)/documents/activities/$(resource.data.activityId)).data.partnerId == request.auth.uid
            && validPartnerSessionUpdate()
          )
        );
      // Fix B B3 — partner peut delete sa session si pas de réservation (V9 freeze).
      // Auparavant : admin-only (Phase 1 conservative). Maintenant cohérent avec
      // Option 3 DELETE endpoint + UX bouton "Supprimer" dans SessionEditModal.
      allow delete: if isAuth()
        && (
          isAdmin()
          || (
            get(/databases/$(database)/documents/activities/$(resource.data.activityId)).data.partnerId == request.auth.uid
            && resource.data.currentParticipants == 0
          )
        );
    }

    // === REVIEWS (Phase 7 T&S — public read si published, anonymisation graduée 1-2★) ===
    // Cf. architecture.md §9.sexies C pour la doctrine.
    // Workflow auto-publication 3-5★ : status='published' direct au create.
    // Workflow modération 1-2★ : status='pending' au create, admin transitionne vers 'published'/'rejected'.
    // Service layer (commit 2/6) garantira reviewerId != revieweeId, participation même session, etc.
    match /reviews/{reviewId} {
      // Read public si la review est publiée. Auteur peut lire ses pending. Admin lit tout.
      allow read: if (resource.data.status == 'published')
        || isAdmin()
        || (isAuth() && resource.data.reviewerId == request.auth.uid);

      // Create par utilisateur authentifié sur son propre compte (anti-spoofing reviewerId).
      // Defense-in-depth :
      // - reviewerId == auth.uid (anti-spoofing)
      // - reviewerId != revieweeId (impossible de se reviewer soi-même)
      // - rating ∈ [1..5], comment longueur 10-500 chars, createdAt == server time
      // - creditsAwarded == false (server-managed, set par allocation bonus crédits ultérieure)
      // - moderatedBy / moderatedAt absents (server-managed, set par admin moderation)
      // - status / anonymized / publishedAt / editableUntil COHÉRENTS avec rating :
      //     rating ≥ 3 → status='published', anonymized=false, publishedAt=now, editableUntil>now
      //     rating ≤ 2 → status='pending', anonymized=true, pas de publishedAt/editableUntil
      //   (anti-bypass modération pré-pub 1-2★ via spoofing status='published' au create)
      allow create: if isAuth()
        && request.resource.data.reviewerId == request.auth.uid
        && request.resource.data.reviewerId != request.resource.data.revieweeId
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5
        && request.resource.data.comment is string
        && request.resource.data.comment.size() >= 10
        && request.resource.data.comment.size() <= 500
        && request.resource.data.createdAt == request.time
        && request.resource.data.creditsAwarded == false
        && !('moderatedBy' in request.resource.data)
        && !('moderatedAt' in request.resource.data)
        && (
             (request.resource.data.rating >= 3
               && request.resource.data.status == 'published'
               && request.resource.data.anonymized == false
               && 'publishedAt' in request.resource.data
               && request.resource.data.publishedAt == request.time
               && 'editableUntil' in request.resource.data
               && request.resource.data.editableUntil > request.time)
             ||
             (request.resource.data.rating <= 2
               && request.resource.data.status == 'pending'
               && request.resource.data.anonymized == true
               && !('publishedAt' in request.resource.data)
               && !('editableUntil' in request.resource.data))
           );

      // Update par auteur uniquement, dans la fenêtre éditable (editableUntil), status doit
      // rester 'published', SEULS comment + rating mutables.
      // Tous les autres champs (status, anonymized, moderation, etc.) sont immuables côté client.
      // Cross-tier rating change INTERDIT (3-5 ↔ 1-2) — anti re-modération bypass post-pub :
      // un user qui a publié 5★ ne peut pas le baisser à 1★ via update (qui resterait
      // anonymized=false illégitimement) ; doit passer par soft-delete service Phase 7
      // + re-création avec rating bas → modération pré-pub appliquée.
      allow update: if isAuth()
        && resource.data.reviewerId == request.auth.uid
        && resource.data.status == 'published'
        && 'editableUntil' in resource.data
        && request.time < resource.data.editableUntil
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['comment', 'rating'])
        && (
             (resource.data.rating >= 3 && request.resource.data.rating >= 3)
             ||
             (resource.data.rating <= 2 && request.resource.data.rating <= 2)
           );

      // Delete admin-only (suppression user passe par soft delete via service Phase 7).
      allow delete: if isAdmin();
    }

    // === REPORTS (Phase 7 T&S sub-chantier 3 — anonymat TOTAL, defense-in-depth) ===
    // Cf. architecture.md §9.sexies D pour la doctrine.
    // Anonymat doctrine §D.1 : reported NE SAIT JAMAIS qui l'a signalé.
    //   → read réservé admin (et reporter pour sa propre history rate-limit check).
    // Auto-trigger sanctions (Phase 7) : service layer client-side trigger via createReport.
    //   Production hardening Phase 8 = Cloud Function on reports create.
    match /reports/{reportId} {
      // Read : admin (queue moderation) OU reporter (vérif rate-limit + history personnelle)
      // Reported NE PEUT JAMAIS lire les reports le concernant (anonymat doctrine §D.1).
      allow read: if isAuth()
        && (isAdmin() || resource.data.reporterId == request.auth.uid);

      // Create : auth + reporterId == auth.uid (anti-spoofing) + anti-self + category enum
      //   + freeTextReason OBLIGATOIRE si category='autre' + status='pending' au create
      //   + createdAt == request.time (anti-backdate)
      //   + source enum (user OU partner_no_show — partner check-in via service)
      //   + champs admin absents (server-managed)
      allow create: if isAuth()
        && request.resource.data.reporterId == request.auth.uid
        && request.resource.data.reportedId is string
        && request.resource.data.reportedId.size() > 0
        && request.resource.data.reporterId != request.resource.data.reportedId
        && request.resource.data.category in [
             'harassment_sexuel',
             'comportement_agressif',
             'fake_profile',
             'substance_etat_problematique',
             'no_show',
             'autre'
           ]
        && (
             request.resource.data.category != 'autre'
             || (request.resource.data.freeTextReason is string
                 && request.resource.data.freeTextReason.size() >= 10)
           )
        && request.resource.data.status == 'pending'
        && request.resource.data.source in ['user', 'partner_no_show']
        && request.resource.data.createdAt == request.time
        && !('reviewedBy' in request.resource.data)
        && !('reviewedAt' in request.resource.data)
        && !('decision' in request.resource.data)
        && !('decisionNote' in request.resource.data)
        && !('resolvedAt' in request.resource.data);

      // Update : admin uniquement (sustain/dismiss + decision note)
      allow update: if isAdmin();

      // Delete : jamais (audit trail conservé doctrine §H 12 mois)
      allow delete: if false;
    }

    // === USER SANCTIONS (Phase 7 T&S sub-chantier 3 — collection séparée audit) ===
    // Cf. architecture.md §9.sexies F pour la doctrine.
    // Source authoritative pour enforcement (login check, banner UI, gating actions).
    // Phase 7 : auto-trigger client-side via createReport service quand threshold atteint.
    //   Anti-DoS : create restrictif sur shape + reason in {reports_threshold, no_show_threshold}.
    //   manual_admin réservé admin (sustainReport flow).
    // Production hardening Phase 8 = Cloud Function trigger anti-spoofing complet.
    match /userSanctions/{sanctionId} {
      // Read : owner (banner UI + appeal flow) OU admin (queue + audit)
      allow read: if isAuth()
        && (resource.data.userId == request.auth.uid || isAdmin());

      // Create : admin (manual) OU auto-trigger via service avec validation shape stricte.
      // Anti-self-sanction (un user ne peut pas se sanctionner lui-même).
      // triggeringReportIds non-vide (au moins 1 report doit avoir déclenché).
      allow create: if isAuth()
        && (
          isAdmin()
          || (
            request.resource.data.userId != request.auth.uid
            && request.resource.data.userId is string
            && request.resource.data.userId.size() > 0
            && request.resource.data.level in [
                 'warning',
                 'suspension_7d',
                 'suspension_30d',
                 'ban_permanent'
               ]
            && request.resource.data.reason in ['reports_threshold', 'no_show_threshold']
            && request.resource.data.triggeringReportIds is list
            && request.resource.data.triggeringReportIds.size() > 0
            && request.resource.data.isActive == true
            && request.resource.data.startsAt == request.time
            && !('appealUsed' in request.resource.data
                  && request.resource.data.appealUsed == true)
            && !('appealResolvedBy' in request.resource.data)
            && !('appealResolvedAt' in request.resource.data)
            && !('appealDecision' in request.resource.data)
          )
        );

      // Update : admin (appeal decisions + désactivation manuelle) OU owner pour file appeal
      // Owner peut SEULEMENT mutater appealUsed=true + appealNote (doctrine §F appel 1×).
      // Toutes autres mutations réservées admin.
      allow update: if isAuth()
        && (
          isAdmin()
          || (
            resource.data.userId == request.auth.uid
            && resource.data.appealable == true
            && resource.data.appealUsed != true
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['appealUsed', 'appealNote'])
            && request.resource.data.appealUsed == true
            && request.resource.data.appealNote is string
            && request.resource.data.appealNote.size() >= 20
          )
        );

      // Delete : jamais (audit trail conservé)
      allow delete: if false;
    }

    // === ADMIN ACTIONS (Phase 7 T&S sub-chantier 5 — audit trail 24 mois) ===
    // Cf. architecture.md §9.sexies H pour la doctrine.
    // Collection séparée — read+create admin only, jamais update ni delete (audit trail).
    match /adminActions/{actionId} {
      // Read : admin only (doctrine §H — audit privé admin team)
      allow read: if isAdmin();

      // Create : 2 paths
      //   (a) Admin actions normales (Phase 7) : isAdmin() + adminId == auth.uid + enum strict
      //   (b) Auto-escalation L4 anti-leak (Phase 8 SC2 commit 5/6) :
      //       any auth user + adminId='system' + actionType='leak_escalation_l4'
      //       + targetType='user' + targetId == auth.uid (self-flag uniquement, anti-spoof)
      //       Rationale : event système déclenché par sendMessage du sender lui-même
      //       (pas un humain admin). Defense-in-depth via constraints strictes.
      allow create: if (
        // Path (a) — admin humain
        isAdmin()
        && request.resource.data.adminId == request.auth.uid
        && request.resource.data.actionType in [
             'review_publish',
             'review_reject',
             'report_dismiss',
             'report_sustain',
             'sanction_overturn',
             'appeal_resolve_upheld',
             'appeal_resolve_overturned',
             'sanction_manual_create'
           ]
        && request.resource.data.targetType in ['review', 'report', 'sanction']
        && request.resource.data.targetId is string
        && request.resource.data.targetId.size() > 0
        && request.resource.data.createdAt == request.time
        && request.resource.data.keys().hasOnly([
             'actionId',
             'adminId',
             'actionType',
             'targetType',
             'targetId',
             'reason',
             'metadata',
             'createdAt'
           ])
      ) || (
        // Path (b) — auto-escalation L4 anti-leak (Phase 8 SC2)
        isAuth()
        && request.resource.data.adminId == 'system'
        && request.resource.data.actionType == 'leak_escalation_l4'
        && request.resource.data.targetType == 'user'
        && request.resource.data.targetId == request.auth.uid
        && request.resource.data.createdAt == request.time
        && request.resource.data.keys().hasOnly([
             'actionId',
             'adminId',
             'actionType',
             'targetType',
             'targetId',
             'metadata',
             'createdAt'
           ])
      );

      // Update : jamais (audit immuable doctrine §H)
      allow update: if false;

      // Delete : jamais (conservation 24 mois — purge cron Phase 9)
      allow delete: if false;
    }

    // === BLOCKS (Phase 7 T&S sub-chantier 2 — invisibilité mutuelle, sans notification) ===
    // Cf. architecture.md §9.sexies E pour la doctrine.
    // Doc-id pattern strict : `${blockerId}_${blockedId}` (déduplication + idempotency).
    // Read autorisé pour les 2 côtés (blocker pour gérer sa liste, blocked pour appliquer
    // côté client le filter mutuel sur discovery/chat). Pas de notification au bloqué :
    // assuré côté UI (pas de toast/email), pas côté rule (le doc reste lisible).
    match /blocks/{blockId} {
      // Read par les 2 côtés (mutuelle invisibilité côté client)
      allow read: if isAuth()
        && (resource.data.blockerId == request.auth.uid
            || resource.data.blockedId == request.auth.uid);

      // Create par blocker uniquement, doc-id pattern enforcé (defense-in-depth) :
      // - blockerId == auth.uid (anti-spoofing)
      // - blockerId != blockedId (anti-self-block)
      // - blockId == `${blockerId}_${blockedId}` (déduplication doc-id)
      // - createdAt == request.time (anti-backdate)
      // - keys hasOnly les 4 champs attendus (anti-payload-injection)
      allow create: if isAuth()
        && request.resource.data.blockerId == request.auth.uid
        && request.resource.data.blockedId is string
        && request.resource.data.blockedId.size() > 0
        && request.resource.data.blockerId != request.resource.data.blockedId
        && blockId == request.resource.data.blockerId + '_' + request.resource.data.blockedId
        && request.resource.data.createdAt == request.time
        && request.resource.data.keys().hasOnly(['blockId', 'blockerId', 'blockedId', 'createdAt']);

      // Immuable (révoquer = delete + re-create, pas un update)
      allow update: if false;

      // Delete par blocker uniquement (réversibilité doctrine §9.sexies E)
      allow delete: if isAuth()
        && resource.data.blockerId == request.auth.uid;
    }

    // === EXCUSES (Phase 9 SC5 — UX no-show grace pré-session) ===
    // Doctrine architecture.md ligne 895 + 2096 : excuse créée ≥ 2h avant session.startAt
    // = no-show NOT comptabilisé (markNoShow skip threshold). Audit trail immuable.
    // Q6=A : owner-only authoring (anti-spoofing userId == auth.uid).
    match /excuses/{excuseId} {
      // Read : owner OU admin (queue audit) — pas exposé publiquement
      allow read: if isAuth()
        && (resource.data.userId == request.auth.uid || isAdmin());

      // Create : owner only (Q6=A) — anti-spoofing userId
      // Defense-in-depth :
      // - userId == auth.uid (anti-spoofing)
      // - createdAt == request.time (anti-backdate)
      // - reason is string + ≤ 300 chars (cohérent EXCUSE_REASON_MAX_LENGTH)
      // - Keys whitelist (anti-injection champs additionnels)
      allow create: if isAuth()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.userId is string
        && request.resource.data.userId.size() > 0
        && request.resource.data.sessionId is string
        && request.resource.data.sessionId.size() > 0
        && request.resource.data.bookingId is string
        && request.resource.data.bookingId.size() > 0
        && request.resource.data.reason is string
        && request.resource.data.reason.size() <= 300
        && request.resource.data.createdAt == request.time
        && request.resource.data.keys().hasOnly(['excuseId', 'userId', 'sessionId', 'bookingId', 'reason', 'createdAt']);

      // Update / Delete : jamais (audit trail immuable, doctrine §9.sexies H pattern)
      allow update: if false;
      allow delete: if false;
    }

  }
}
