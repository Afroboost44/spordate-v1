rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // === HELPERS ===
    function isAuth() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return request.auth.uid == uid;
    }
    function isAdmin() {
      return isAuth()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // Phase 6 anti-cheat V7 — interdit le downgrade de Session.maxParticipants sous currentParticipants.
    // Autorise : upgrade (5→10), no-change, ou égalité (5→5 = ferme aux nouvelles bookings).
    // Bloque  : downgrade strict (8→3 si currentParticipants=5).
    // Admin skip cette garde via la branche isAdmin() du allow update sessions — emergency edits permises.
    // Note : helper spécifique sessions/{id} (accède maxParticipants + currentParticipants) ; n'invoquer
    //        que depuis ce match block, sinon résultats imprévisibles sur autres collections.
    function validMaxParticipantsUpdate() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(['maxParticipants'])
        || request.resource.data.maxParticipants >= resource.data.currentParticipants;
    }

    // Phase 6 anti-cheat V9 — interdit toute modification de Session.pricingTiers après le 1er booking.
    // Autorise : modification libre tant que currentParticipants == 0 (avant tout booking, workflow normal pré-launch).
    // Bloque  : toute modif (price, deletion d'un tier, ajout d'un tier) si currentParticipants > 0.
    // Admin skip cette garde via la branche isAdmin() du allow update sessions — emergency edits permises.
    // Note : helper spécifique sessions/{id} (accède pricingTiers + currentParticipants) ; n'invoquer
    //        que depuis ce match block, sinon résultats imprévisibles sur autres collections.
    function validPricingTiersUpdate() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(['pricingTiers'])
        || resource.data.currentParticipants == 0;
    }

    // === USERS ===
    match /users/{userId} {
      allow read: if isAuth();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();

      match /preferences/{doc} {
        allow read, write: if isOwner(userId);
      }
    }

    // === MATCHES ===
    match /matches/{matchId} {
      allow read: if isAuth() && request.auth.uid in resource.data.userIds;
      allow create: if isAuth();
      allow update: if isAuth() && request.auth.uid in resource.data.userIds;
      allow delete: if isAdmin();
    }

    // === ACTIVITIES (public read, partner CRUD) ===
    match /activities/{activityId} {
      allow read: if true;
      allow create: if isAuth();
      allow update: if isAuth() && (resource.data.partnerId == request.auth.uid || isAdmin());
      allow delete: if isAuth() && (resource.data.partnerId == request.auth.uid || isAdmin());
    }

    // === BOOKINGS ===
    match /bookings/{bookingId} {
      allow read: if isAuth() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuth();
      allow update: if isAdmin();
      allow delete: if false;
    }

    // === CREDITS (server-side only) ===
    match /credits/{creditId} {
      allow read: if isAuth() && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    // === TRANSACTIONS (server-side only) ===
    match /transactions/{transactionId} {
      allow read: if isAuth() && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if false;
    }

    // === CREATORS ===
    match /creators/{creatorId} {
      allow read: if isAuth();
      allow create: if isOwner(creatorId);
      allow update: if isOwner(creatorId) || isAdmin();
      allow delete: if isAdmin();
    }

    // === PARTNERS (public read) ===
    match /partners/{partnerId} {
      allow read: if true;
      allow create: if isAuth();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // === REFERRALS (server-side only) ===
    match /referrals/{referralId} {
      allow read: if isAuth()
        && (resource.data.referrerId == request.auth.uid
            || resource.data.referredUserId == request.auth.uid
            || isAdmin());
      allow write: if false;
    }

    // === PAYOUTS ===
    match /payouts/{payoutId} {
      allow read: if isAuth()
        && (resource.data.creatorId == request.auth.uid || isAdmin());
      allow create: if isAuth()
        && request.resource.data.creatorId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if false;
    }

    // === ANALYTICS (admin only) ===
    match /analytics/{doc=**} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // === CHATS ===
    match /chats/{chatId} {
      allow read: if isAuth() && request.auth.uid in resource.data.participants;
      allow create: if isAuth() && request.auth.uid in request.resource.data.participants;
      allow update: if isAuth() && request.auth.uid in resource.data.participants;
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isAuth()
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow create: if isAuth()
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants
          && get(/databases/$(database)/documents/matches/$(chatId)).data.chatUnlocked == true
          // Phase 1 (additif) : verrouillage temporel basé sur la session liée.
          // Si le match n'a pas de sessionId (legacy) → comportement inchangé.
          // Sinon → refuser le create si la session est 'completed' ou 'cancelled'.
          && (
            !('sessionId' in get(/databases/$(database)/documents/matches/$(chatId)).data)
            || get(/databases/$(database)/documents/matches/$(chatId)).data.sessionId == ''
            || !(get(/databases/$(database)/documents/sessions/$(get(/databases/$(database)/documents/matches/$(chatId)).data.sessionId)).data.status in ['completed', 'cancelled'])
          );
        allow update, delete: if false;
      }
    }

    // === NOTIFICATIONS (anyone can create for partner requests, owner reads, admin manages) ===
    match /notifications/{notificationId} {
      allow read: if isAuth() && (resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isAuth() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if true;
      allow delete: if isAdmin();
    }

    // === BOOSTS (public read for discovery, authenticated create) ===
    match /boosts/{boostId} {
      allow read: if true;
      allow create: if isAuth();
      allow update: if isAuth() && (resource.data.partnerId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    // === PARTNER REQUESTS (public create, admin read/update) ===
    match /partnerRequests/{requestId} {
      allow create: if true;
      allow read, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // === ERROR LOGS ===
    match /errorLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuth();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // === SETTINGS (admin only — pricing, config, etc.) ===
    match /settings/{doc} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // === PRICING (admin only) ===
    match /pricing/{doc} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // === PROMOS (admin only) ===
    match /promos/{doc} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // === SESSIONS ===
    // Occurrences datées d'une Activity (Phase 1 du système "Dates par Activités").
    // Les champs currentParticipants/currentTier/currentPrice ne sont écrits QUE par le serveur
    // (webhook Stripe + crons Phase 7) via l'Admin SDK qui bypass les rules.
    //
    // Phase 5 : read PUBLIC (cohérent avec activities/ ligne 39 — pas de PII dans les
    // documents session, contenu marketing/discovery indispensable au SSR de /sessions
    // sans login. Le ReserveButton déclenche le redirect login uniquement au clic.).
    match /sessions/{sessionId} {
      allow read: if true;
      allow create: if isAuth()
        && (
          isAdmin()
          || get(/databases/$(database)/documents/activities/$(request.resource.data.activityId)).data.partnerId == request.auth.uid
        );
      allow update: if isAuth()
        && (
          isAdmin()
          || (
            get(/databases/$(database)/documents/activities/$(resource.data.activityId)).data.partnerId == request.auth.uid
            && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['currentParticipants', 'currentTier', 'currentPrice'])
            && validMaxParticipantsUpdate()
            && validPricingTiersUpdate()
          )
        );
      allow delete: if isAdmin();
    }

    // === REVIEWS (Phase 7 T&S — public read si published, anonymisation graduée 1-2★) ===
    // Cf. architecture.md §9.sexies C pour la doctrine.
    // Workflow auto-publication 3-5★ : status='published' direct au create.
    // Workflow modération 1-2★ : status='pending' au create, admin transitionne vers 'published'/'rejected'.
    // Service layer (commit 2/6) garantira reviewerId != revieweeId, participation même session, etc.
    match /reviews/{reviewId} {
      // Read public si la review est publiée. Auteur peut lire ses pending. Admin lit tout.
      allow read: if (resource.data.status == 'published')
        || isAdmin()
        || (isAuth() && resource.data.reviewerId == request.auth.uid);

      // Create par utilisateur authentifié sur son propre compte (anti-spoofing reviewerId).
      // Defense-in-depth :
      // - reviewerId == auth.uid (anti-spoofing)
      // - reviewerId != revieweeId (impossible de se reviewer soi-même)
      // - rating ∈ [1..5], comment longueur 10-500 chars, createdAt == server time
      // - creditsAwarded == false (server-managed, set par allocation bonus crédits ultérieure)
      // - moderatedBy / moderatedAt absents (server-managed, set par admin moderation)
      // - status / anonymized / publishedAt / editableUntil COHÉRENTS avec rating :
      //     rating ≥ 3 → status='published', anonymized=false, publishedAt=now, editableUntil>now
      //     rating ≤ 2 → status='pending', anonymized=true, pas de publishedAt/editableUntil
      //   (anti-bypass modération pré-pub 1-2★ via spoofing status='published' au create)
      allow create: if isAuth()
        && request.resource.data.reviewerId == request.auth.uid
        && request.resource.data.reviewerId != request.resource.data.revieweeId
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5
        && request.resource.data.comment is string
        && request.resource.data.comment.size() >= 10
        && request.resource.data.comment.size() <= 500
        && request.resource.data.createdAt == request.time
        && request.resource.data.creditsAwarded == false
        && !('moderatedBy' in request.resource.data)
        && !('moderatedAt' in request.resource.data)
        && (
             (request.resource.data.rating >= 3
               && request.resource.data.status == 'published'
               && request.resource.data.anonymized == false
               && 'publishedAt' in request.resource.data
               && request.resource.data.publishedAt == request.time
               && 'editableUntil' in request.resource.data
               && request.resource.data.editableUntil > request.time)
             ||
             (request.resource.data.rating <= 2
               && request.resource.data.status == 'pending'
               && request.resource.data.anonymized == true
               && !('publishedAt' in request.resource.data)
               && !('editableUntil' in request.resource.data))
           );

      // Update par auteur uniquement, dans la fenêtre éditable (editableUntil), status doit
      // rester 'published', SEULS comment + rating mutables.
      // Tous les autres champs (status, anonymized, moderation, etc.) sont immuables côté client.
      // Cross-tier rating change INTERDIT (3-5 ↔ 1-2) — anti re-modération bypass post-pub :
      // un user qui a publié 5★ ne peut pas le baisser à 1★ via update (qui resterait
      // anonymized=false illégitimement) ; doit passer par soft-delete service Phase 7
      // + re-création avec rating bas → modération pré-pub appliquée.
      allow update: if isAuth()
        && resource.data.reviewerId == request.auth.uid
        && resource.data.status == 'published'
        && 'editableUntil' in resource.data
        && request.time < resource.data.editableUntil
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['comment', 'rating'])
        && (
             (resource.data.rating >= 3 && request.resource.data.rating >= 3)
             ||
             (resource.data.rating <= 2 && request.resource.data.rating <= 2)
           );

      // Delete admin-only (suppression user passe par soft delete via service Phase 7).
      allow delete: if isAdmin();
    }

    // === BLOCKS (Phase 7 T&S sub-chantier 2 — invisibilité mutuelle, sans notification) ===
    // Cf. architecture.md §9.sexies E pour la doctrine.
    // Doc-id pattern strict : `${blockerId}_${blockedId}` (déduplication + idempotency).
    // Read autorisé pour les 2 côtés (blocker pour gérer sa liste, blocked pour appliquer
    // côté client le filter mutuel sur discovery/chat). Pas de notification au bloqué :
    // assuré côté UI (pas de toast/email), pas côté rule (le doc reste lisible).
    match /blocks/{blockId} {
      // Read par les 2 côtés (mutuelle invisibilité côté client)
      allow read: if isAuth()
        && (resource.data.blockerId == request.auth.uid
            || resource.data.blockedId == request.auth.uid);

      // Create par blocker uniquement, doc-id pattern enforcé (defense-in-depth) :
      // - blockerId == auth.uid (anti-spoofing)
      // - blockerId != blockedId (anti-self-block)
      // - blockId == `${blockerId}_${blockedId}` (déduplication doc-id)
      // - createdAt == request.time (anti-backdate)
      // - keys hasOnly les 4 champs attendus (anti-payload-injection)
      allow create: if isAuth()
        && request.resource.data.blockerId == request.auth.uid
        && request.resource.data.blockedId is string
        && request.resource.data.blockedId.size() > 0
        && request.resource.data.blockerId != request.resource.data.blockedId
        && blockId == request.resource.data.blockerId + '_' + request.resource.data.blockedId
        && request.resource.data.createdAt == request.time
        && request.resource.data.keys().hasOnly(['blockId', 'blockerId', 'blockedId', 'createdAt']);

      // Immuable (révoquer = delete + re-create, pas un update)
      allow update: if false;

      // Delete par blocker uniquement (réversibilité doctrine §9.sexies E)
      allow delete: if isAuth()
        && resource.data.blockerId == request.auth.uid;
    }

  }
}
