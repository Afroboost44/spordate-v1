# --- Firebase ---
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSy...
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=spordateur-claude.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=spordateur-claude
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=spordateur-claude.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abcdef

# Firebase Admin (pour le webhook Stripe côté serveur)
# Généré depuis Firebase Console → Project Settings → Service Accounts
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"spordateur-claude",...}

# --- Stripe ---
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- App ---
NEXT_PUBLIC_APP_URL=https://spordateur.com
